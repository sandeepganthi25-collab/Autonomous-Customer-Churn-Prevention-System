# Autonomous Churn Prevention System - Environment Variables

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database (PostgreSQL - for production)
DATABASE_URL=postgresql://user:password@localhost:5432/churn_prevention

# Redis (for caching and real-time events)
REDIS_URL=redis://localhost:6379

# Twilio (SMS - mock in development)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email - mock in development)
SENDGRID_API_KEY=your-sendgrid-key

# Firebase (Push Notifications - mock in development)
FIREBASE_API_KEY=your-firebase-key
FIREBASE_PROJECT_ID=your-project

# Kafka (Real-time events - mock in development)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MLflow (Model tracking)
MLFLOW_TRACKING_URI=http://localhost:5000

# Environment
NODE_ENV=development
